# =============================================================================
# Doomsday Prep Platform — Environment Variables
# Copy to .env and fill in all values before running.
# In production, populate via GitHub secret PROD_ENV (GitHub Actions deploy).
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
POSTGRES_USER=doomsday
POSTGRES_PASSWORD=changeme
# Local dev: use localhost. Docker/prod: set by docker-compose.prod.yml override
DATABASE_URL=postgresql+asyncpg://doomsday:changeme@localhost:5432/doomsday

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Auth / JWT
# -----------------------------------------------------------------------------
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# LLM (model-agnostic — swap via this config)
# -----------------------------------------------------------------------------
LLM_PROVIDER=ollama
LLM_MODEL=qwen3.5:35b-a3b
LLM_BASE_URL=http://host.docker.internal:11434
LLM_MAX_RETRIES=3
LLM_TIMEOUT=120

# -----------------------------------------------------------------------------
# News APIs
# -----------------------------------------------------------------------------
NEWS_API_KEY=
GDELT_ENABLED=true

# -----------------------------------------------------------------------------
# IP Geolocation
# -----------------------------------------------------------------------------
IPAPI_URL=http://ip-api.com/json

# -----------------------------------------------------------------------------
# Cloudflare
# -----------------------------------------------------------------------------
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_PAGES_PROJECT=doomsday-fallback

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
GUIDE_RATE_LIMIT_PER_HOUR=5
GUIDE_RATE_LIMIT_WINDOW=3600

# -----------------------------------------------------------------------------
# Doomsday Clock
# -----------------------------------------------------------------------------
CLOCK_SCAN_INTERVAL_HOURS=6
CLOCK_ANCHOR_SECONDS=85
CLOCK_MAX_DELTA_PER_SCAN=5
RELATIONS_UPDATE_INTERVAL_HOURS=24

# -----------------------------------------------------------------------------
# VAPID keys (Web Push notifications)
# Generate with: python backend/scripts/generate_vapid.py
# -----------------------------------------------------------------------------
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=your@email.com

# -----------------------------------------------------------------------------
# CORS (production)
# Comma-separated list of allowed origins. In dev, typically http://localhost:3000
# In production, set to your public domain(s).
# Example: https://doomsday.example.com,https://www.doomsday.example.com
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Frontend
# Set to your public API base URL (no trailing slash).
# Used at Next.js build time (baked into the static bundle).
# Local dev: http://localhost:8000
# Production: https://yourdomain.com  (nginx routes /api/* to backend)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# VAPID public key for the browser (must match VAPID_PUBLIC_KEY above)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
